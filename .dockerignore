# Build context for mcp/deploy/Dockerfile — deploy from the repo root:
#   fly deploy --config mcp/deploy/fly.toml

# Rebuilt inside the image
node_modules
**/node_modules

# Secrets — NEVER ship these
.env
.env.*

# Not needed in the image (keeps the build context small). dist/ IS needed — don't ignore it,
# EXCEPT the ~344MB f32 endpoint-vector cache: the server loads the ~86MB int8 index
# (dist/endpoint-index.i8.*) instead, and the Dockerfile deletes dist/cache anyway.
dist/cache
.git
.github
docs
src
eval
.DS_Store
*.log
**/*.log
mcp/_smoke.mjs
