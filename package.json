{
  "name": "paid-api-graph",
  "version": "0.1.0",
  "description": "Vendor-neutral ontology and index for x402 and MPP paid API endpoints",
  "type": "module",
  "license": "MIT",
  "bin": {
    "capindex": "./dist/cli.js"
  },
  "files": [
    "dist",
    "spec",
    "ontology"
  ],
  "scripts": {
    "build:ts": "tsc",
    "build:index": "node dist/cli.js build",
    "build": "npm run build:ts && npm run build:index",
    "test": "node --test dist/**/*.test.js",
    "validate": "node dist/cli.js validate",
    "search": "node dist/cli.js search"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^13.1.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}