{
  "name": "oasis",
  "version": "0.1.0",
  "description": "Vendor-neutral ontology and index for x402 and MPP paid API endpoints",
  "repository": {
    "type": "git",
    "url": "https://github.com/Syntalic/OASIS.git"
  },
  "homepage": "https://syntalic.com",
  "type": "module",
  "license": "MIT",
  "bin": {
    "capindex": "./dist/cli.js"
  },
  "files": [
    "dist",
    "spec",
    "ontology"
  ],
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build:ts": "tsc",
    "build:index": "node dist/cli.js build",
    "build:endpoint-index": "node scripts/build-endpoint-index.mjs",
    "ingest": "node dist/cli.js ingest",
    "enrich": "node dist/enrich-facets.js dist",
    "build": "pnpm run build:ts && pnpm run ingest && pnpm run enrich",
    "test": "node --test 'dist/**/*.test.js'",
    "test:unit": "node --test dist/id.test.js dist/intent-match.test.js dist/search.test.js dist/openapi-parser.test.js dist/related.test.js dist/eval/url-match.test.js",
    "eval": "node dist/cli.js eval",
    "eval:resolve": "node dist/cli.js eval:resolve",
    "eval:hybrid": "node dist/cli.js eval:hybrid",
    "eval:compare": "node dist/cli.js eval:compare",
    "eval:multi": "node dist/cli.js eval:multi",
    "eval:heldout": "node dist/cli.js eval:heldout",
    "eval:bridges": "node dist/cli.js eval:bridges",
    "eval:usefulness": "node dist/cli.js eval:usefulness",
    "benchmark": "pnpm run build:ts && pnpm test && pnpm run eval:resolve && pnpm run eval:compare -- --offline --methods full,endpoints-only,pay-skills-only,x402scan-only,mpp-only,full-hybrid",
    "eval:generate": "pnpm run build:ts && node dist/eval/generate-queries.js",
    "embed": "node dist/cli.js embed --scope curated",
    "validate": "node dist/cli.js validate",
    "search": "node dist/cli.js search"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.30.0",
    "@xenova/transformers": "^2.17.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^13.1.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
