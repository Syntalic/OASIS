{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Syntalic/OASIS/spec/endpoint-record.schema.json",
  "title": "EndpointRecord",
  "type": "object",
  "required": [
    "id",
    "origin",
    "method",
    "path",
    "summary",
    "payment",
    "search_text",
    "built_at"
  ],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "origin": { "type": "string", "format": "uri" },
    "method": {
      "type": "string",
      "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]
    },
    "path": { "type": "string", "minLength": 1 },
    "operation_id": { "type": "string" },
    "summary": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "provider_fqn": { "type": "string" },
    "provider_title": { "type": "string" },
    "category": { "type": "string" },
    "capabilities": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9._-]*$" }
    },
    "inputs": { "type": "array", "items": { "type": "string" } },
    "facets": { "$ref": "#/$defs/EndpointFacets" },
    "payment": { "$ref": "#/$defs/Payment" },
    "service": { "$ref": "#/$defs/ServiceInfo" },
    "responses": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "has200": { "type": "boolean" },
        "has402": { "type": "boolean" }
      }
    },
    "schema_missing": { "type": "boolean" },
    "guidance_available": { "type": "boolean" },
    "openapi_url": { "type": "string", "format": "uri" },
    "search_text": { "type": "string" },
    "built_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "EndpointFacets": {
      "type": "object",
      "additionalProperties": false,
      "description": "Derived facets caching the path/summary/inputs signal. Not new information.",
      "properties": {
        "domain": {
          "enum": [
            "commerce",
            "ai",
            "data",
            "web",
            "comms",
            "finance",
            "maps",
            "travel",
            "realestate",
            "social",
            "media",
            "cloud",
            "compute",
            "devtools",
            "blockchain",
            "identity",
            "agent",
            "utility",
            "science",
            "gov"
          ]
        },
        "primary_entity": { "type": "string" },
        "output_entity": { "type": "string" },
        "modality": {
          "type": "array",
          "items": {
            "enum": [
              "text",
              "html",
              "markdown",
              "json",
              "image",
              "audio",
              "vector",
              "citations",
              "timeseries"
            ]
          }
        }
      }
    },
    "PaymentRail": {
      "type": "object",
      "required": ["protocol"],
      "properties": {
        "protocol": { "type": "string", "enum": ["x402", "mpp"] },
        "version": { "type": "string" },
        "networks": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Payment": {
      "type": "object",
      "required": ["rails"],
      "properties": {
        "price_usd": { "type": "number", "minimum": 0 },
        "paid": { "type": "boolean" },
        "currency": { "type": "string" },
        "rails": {
          "type": "array",
          "items": { "$ref": "#/$defs/PaymentRail" }
        },
        "offers": {
          "type": "array",
          "items": { "$ref": "#/$defs/PaymentOffer" }
        }
      }
    },
    "PaymentOffer": {
      "type": "object",
      "required": ["intent", "method", "amount"],
      "properties": {
        "intent": { "type": "string", "enum": ["charge", "session"] },
        "method": { "type": "string" },
        "amount": { "type": ["string", "null"] },
        "currency": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "ServiceInfo": {
      "type": "object",
      "properties": {
        "categories": { "type": "array", "items": { "type": "string" } },
        "docs": {
          "type": "object",
          "properties": {
            "apiReference": { "type": "string" },
            "homepage": { "type": "string" },
            "llms": { "type": "string" }
          }
        }
      }
    }
  }
}