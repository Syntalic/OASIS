{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://syntalic.com/oasis/spec/capability.schema.json",
  "title": "CapabilityIntent",
  "type": "object",
  "required": ["id", "label", "satisfies"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9._-]*$" },
    "label": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "schema_org": { "type": "array", "items": { "type": "string" } },
    "related": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9._-]*$" }
    },
    "satisfies": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/SatisfiesRef" }
    }
  },
  "$defs": {
    "SatisfiesRef": {
      "type": "object",
      "required": ["origin", "method", "path"],
      "properties": {
        "origin": { "type": "string", "format": "uri" },
        "method": { "type": "string" },
        "path": { "type": "string" },
        "confidence": {
          "type": "string",
          "enum": ["primary", "secondary", "fallback"]
        },
        "notes": { "type": "string" }
      }
    }
  }
}