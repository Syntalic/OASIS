{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Syntalic/OASIS/spec/entity-vocab.json",
  "title": "EntityVocab",
  "description": "Closed controlled vocabulary of typed nouns referenced by intent consumes/produces ports. kind ∈ identity|observation|abstract. bridge_eligible marks v1 lateral seeds (identity only).",
  "spec_version": "0.3.0",
  "entities": {
    "Product": { "role": "identifier", "kind": "identity", "schema_org": ["Product"] },
    "ProductCategory": { "role": "identifier", "kind": "identity", "bridge_eligible": true },
    "PriceSignal": {
      "role": "payload",
      "kind": "observation",
      "bridge_eligible": false,
      "schema_org": ["PriceSpecification"],
      "absorbs": ["PriceQuote", "PriceHistory", "InflationTrend"]
    },
    "Money": { "role": "constraint", "kind": "identity", "schema_org": ["MonetaryAmount"] },
    "Currency": { "role": "identifier", "kind": "identity" },
    "Query": { "role": "identifier", "kind": "identity", "bridge_eligible": false },
    "Topic": { "role": "identifier", "kind": "identity", "bridge_eligible": false },
    "Answer": {
      "role": "payload",
      "kind": "observation",
      "bridge_eligible": false,
      "absorbs": ["SearchResults", "CitedAnswer", "ComputedAnswer"]
    },
    "SearchResults": { "role": "payload", "kind": "observation" },
    "CitedAnswer": { "role": "payload", "kind": "observation" },
    "Webpage": { "role": "identifier", "kind": "identity", "schema_org": ["WebPage"] },
    "WebContent": { "role": "payload", "kind": "observation", "schema_org": ["CreativeWork"] },
    "Document": { "role": "identifier", "kind": "identity", "schema_org": ["DigitalDocument"] },
    "StructuredRecord": { "role": "payload", "kind": "observation", "bridge_eligible": false, "deprecated": true },
    "Image": { "role": "payload", "kind": "observation", "schema_org": ["ImageObject"] },
    "AudioClip": { "role": "payload", "kind": "observation", "schema_org": ["AudioObject"] },
    "Text": { "role": "payload", "kind": "observation", "schema_org": ["Text"] },
    "Embedding": { "role": "payload", "kind": "observation" },
    "Contact": { "role": "identifier", "kind": "identity", "absorbs": ["EmailAddress", "PhoneNumber"] },
    "Message": {
      "role": "payload",
      "kind": "observation",
      "absorbs": ["EmailMessage", "SmsMessage", "Fax", "PhoneCall"]
    },
    "Mailbox": { "role": "identifier", "kind": "identity" },
    "Location": { "role": "identifier", "kind": "identity", "deprecated": true, "absorbed_by": "Place" },
    "Place": { "role": "identifier", "kind": "identity", "bridge_eligible": true, "schema_org": ["Place", "LocalBusiness"], "absorbs": ["Location", "PostalAddress", "GeoCoordinates", "City", "Region"] },
    "Company": { "role": "identifier", "kind": "identity", "bridge_eligible": true, "schema_org": ["Organization"], "absorbs": ["Brand"] },
    "Brand": { "role": "identifier", "kind": "identity", "bridge_eligible": false },
    "Person": { "role": "identifier", "kind": "identity", "bridge_eligible": true, "schema_org": ["Person"] },
    "SocialProfile": { "role": "payload", "kind": "observation", "bridge_eligible": false },
    "MarketQuote": {
      "role": "payload",
      "kind": "observation",
      "bridge_eligible": false,
      "absorbs": ["StockQuote", "CryptoPrice"]
    },
    "CryptoAsset": { "role": "identifier", "kind": "identity", "bridge_eligible": false },
    "WalletAddress": { "role": "identifier", "kind": "identity", "bridge_eligible": false },
    "BlockchainNetwork": { "role": "identifier", "kind": "identity", "bridge_eligible": false },
    "Ticker": { "role": "identifier", "kind": "identity", "bridge_eligible": false },
    "Domain": { "role": "identifier", "kind": "identity", "bridge_eligible": true },
    "DnsRecord": { "role": "payload", "kind": "observation", "bridge_eligible": false },
    "IpAddress": { "role": "identifier", "kind": "identity", "bridge_eligible": false },
    "PostalAddress": { "role": "identifier", "kind": "identity", "deprecated": true, "absorbed_by": "Place" },
    "GeoCoordinates": { "role": "payload", "kind": "identity", "deprecated": true, "absorbed_by": "Place" },
    "GovernmentService": { "role": "payload", "kind": "observation", "bridge_eligible": false },
    "WeatherReport": { "role": "payload", "kind": "observation", "bridge_eligible": false },
    "PredictionMarket": { "role": "payload", "kind": "observation" },
    "TradingSignal": { "role": "payload", "kind": "observation", "bridge_eligible": false },
    "ScientificEntity": { "role": "payload", "kind": "observation", "bridge_eligible": false },
    "CodeRepository": { "role": "payload", "kind": "observation", "bridge_eligible": false, "schema_org": ["SoftwareSourceCode"] },
    "EconomicIndicator": { "role": "payload", "kind": "observation", "bridge_eligible": false },
    "MemoryKey": { "role": "identifier", "kind": "identity" },
    "MemoryEntry": { "role": "payload", "kind": "observation" },
    "AgentProfile": { "role": "payload", "kind": "observation" }
  }
}